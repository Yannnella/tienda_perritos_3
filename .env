# Puertos locales en tu computadora
FRONTEND_PORT=80
BACKEND_PORT=3001
DB_PORT=3306

# Configuración de Base de Datos para Docker Compose
# (El host debe llamarse "db" porque es el nombre del servicio de la BD en este Compose)
DB_HOST=db
DB_NAME=tienda_perritos
DB_USER=root
DB_ROOT_PASSWORD=admin123
